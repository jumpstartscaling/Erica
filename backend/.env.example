# Tranzformation Nation -- environment template.
# Copy to backend/.env and edit. NEVER commit the real .env (see .gitignore).

# --- Core ---
# Used to sign session cookies. Generate a strong value for production:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-insecure-change-me

# Public base URL (used in the stubbed verification email link).
APP_BASE_URL=http://localhost:8000

# Set true ONLY behind HTTPS in production (marks the session cookie Secure).
COOKIE_SECURE=false

# --- Database ---
# Empty -> SQLite file backend/app.db (default; runs with one command).
# To use Postgres instead, set e.g.:
#   DATABASE_URL=postgresql://user:pass@localhost:5432/tranzformation
# (also uncomment psycopg in backend/requirements.txt)
DATABASE_URL=
# Optional override for the SQLite file path:
# SQLITE_PATH=./backend/app.db

# --- Webinar ---
# PLACEHOLDER YouTube id. Replace with the real (unlisted) training id in prod.
# Never hard-code real video ids in public HTML (see PUBLIC_VIEW_CHANGES.md).
WEBINAR_YOUTUBE_ID=dQw4w9WgXcQ

# --- Payments (STUBBED) ---
# Leave false until legal/CROA review is complete. /api/checkout returns 503.
CHECKOUT_ENABLED=false
# TODO(Stripe): STRIPE_SECRET_KEY=, STRIPE_WEBHOOK_SECRET=
# TODO(Cal.com): CALCOM_EMBED_LINK=, CALCOM_WEBHOOK_SECRET=

# --- Offer prices (display only) ---
PRICE_COURSE=35
PRICE_COACHING_SINGLE=75
PRICE_COACHING_PACKAGE=200
